## Store — `useImageStore`

Singleton via refs a nivel de módulo (fuera de la función composable).
Todos los componentes llaman al store directamente — sin prop-drilling para mutaciones.

```typescript
// Estado module-level — persiste entre montajes
const items        = ref<ImageItem[]>([])
const activeItemId = ref<string | null>(null)

export function useImageStore() {
  // computed
  activeItem    // ImageItem | null
  totalOutputs  // sum de exportConfigs.length

  // mutaciones
  add(raw: RawImageData[])
  remove(id: string)
  setActive(id: string)
  rename(id: string, name: string)
  setStatus(id: string, status: ImageItemStatus)
  setCrop(id: string, crop: CropState | undefined)
  setFilters(id: string, filters: Partial<FilterState>)
  addExportConfig(itemId: string)
  removeExportConfig(itemId: string, configId: string)
  updateExportConfig(itemId: string, configId: string, patch: Partial<ExportConfig>)
}
```

