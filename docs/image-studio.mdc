## Tipos — `types/imageStudio.ts`

```typescript
export type ImageItemStatus = 'idle' | 'exporting' | 'done' | 'error'
export type ResizeMode      = 'original' | 'width' | 'height'

export interface FilterState {
  brightness: number; contrast: number; saturation: number
  shadows: number; sharpness: number; temperature: number
}

export interface RawImageData {
  file: File; dataUrl: string
  naturalWidth: number; naturalHeight: number; sizeBytes: number
}

export interface ImageItem {
  id: string; name: string; status: ImageItemStatus
  source: { file, dataUrl, naturalWidth, naturalHeight, sizeBytes }
  crop?: CropState
  filters: FilterState
  exportConfigs: ExportConfig[]
}

export interface ExportConfig {
  id: string; label: string
  format: 'jpeg' | 'webp' | 'png'
  quality: number                // 0–100
  resize: { mode: ResizeMode; value?: number }
}
```

