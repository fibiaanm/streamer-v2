# Etapa 01 — Fundación

## Objetivo

Base de datos completa del assistant, modelos Eloquent, planes seeder y skeleton del servicio Node. Al terminar esta etapa existe todo el andamiaje de datos y el servicio puede levantarse en Docker.

---

## Migraciones — orden y campos clave

Los archivos siguen la numeración global del proyecto (`0036`–`0050`) para respetar el orden de ejecución con las migraciones existentes.

```
0036_add_assistant_fields_to_users
  + timezone          string IANA, default 'UTC'
  + default_currency  string ISO 4217, default 'USD'
  + username          string unique nullable
  + friend_code       string unique           — generado en RegisterUseCase

0037_create_assistant_conversations_table
  id, user_id FK users, created_at

0038_create_assistant_sessions_table
  id, conversation_id FK, started_at, last_message_at

0039_create_assistant_messages_table
  id, conversation_id FK, session_id FK
  role          enum: user | assistant | system | tool_call | tool_result
  channel       enum: web | whatsapp, default web
  content       text
  actions_json  json nullable
  metadata_json json nullable
  memory_processed bool default false
  created_at
  -- media via Spatie (morphs)

0040_create_memories_table
  id, user_id FK
  category    string
  description string
  content     text
  updated_at, created_at
  UNIQUE(user_id, category)

0041_create_type_catalogs_table
  id
  user_id FK nullable
  domain  string (event | list | expense)
  name    string
  INDEX(domain)
  UNIQUE(user_id, domain, name)

0042_create_assistant_events_table
  id, user_id FK
  content         text
  event_at        timestamp UTC
  event_end       timestamp UTC nullable
  type            string
  recurrence_rule string nullable   — solo en masters de serie
  status          enum: active | cancelled | completed, default active
  sender_id       FK users nullable
  created_at, updated_at
  softDeletes

  — columnas añadidas en etapa 04 (migración 0051):
  series_id              bigint nullable FK → assistant_events(id) ON DELETE SET NULL
  occurrence_at          timestamp nullable   — slot RRULE que esta fila representa
  reminders_template_json json nullable       — plantilla de offsets en masters recurrentes
  referenceable_type     string nullable      — migración 0052
  referenceable_id       string nullable

0043_create_event_reminders_table
  id, event_id FK
  fire_at   timestamp UTC
  message   string
  status    enum: pending | fired | failed, default pending
  fired_at  timestamp nullable
  created_at

0044_create_assistant_lists_table
  id, user_id FK
  name    string
  type    string nullable
  created_at, updated_at
  softDeletes

0045_create_list_items_table
  id, list_id FK
  content           string
  status            enum: pending | done, default pending
  position          integer default 0
  added_by_user_id  FK users
  created_at, updated_at

0046_create_expenses_table
  id, user_id FK
  amount_cents  integer
  currency      string ISO 4217
  description   string
  type          string nullable
  spent_at      timestamp UTC
  created_at, updated_at

0047_create_friendships_table
  id
  requester_id FK users
  addressee_id FK users
  status  enum: pending | accepted | declined | blocked, default pending
  created_at, updated_at
  UNIQUE(requester_id, addressee_id)

0048_create_friend_labels_table
  id
  user_id        FK users
  friend_user_id FK users
  label          string
  created_at, updated_at
  UNIQUE(user_id, friend_user_id)

0049_create_list_shares_table
  id
  list_id              FK assistant_lists
  shared_with_user_id  FK users
  invited_by_user_id   FK users
  permission           enum: read | write, default read
  accepted_at          timestamp nullable
  created_at
  (sin timestamps automáticos)

0050_create_reminder_requests_table
  id
  sender_id          FK users
  receiver_id        FK users
  content            string
  suggested_event_at timestamp nullable
  status             enum: pending | accepted | declined, default pending
  event_id           FK assistant_events nullable
  message_id         FK assistant_messages nullable
  created_at, updated_at
```

