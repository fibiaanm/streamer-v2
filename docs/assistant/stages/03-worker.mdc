## ModelResolver

```ts
function resolveModel(userPlanTier: 'free' | 'paid', context: 'main' | 'memory'): Model {
  if (context === 'memory') return { provider: 'anthropic', modelId: 'claude-haiku-4-5' }
  if (userPlanTier === 'paid') return { provider: 'anthropic', modelId: 'claude-sonnet-4-6' }
  return { provider: 'anthropic', modelId: 'claude-haiku-4-5' }
}
```

