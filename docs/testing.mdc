## Factories realistas

Cada dominio tiene su factory con estados expresivos:

```php
// database/factories/WorkspaceFactory.php
class WorkspaceFactory extends Factory
{
    public function orphaned(): static
    {
        return $this->state(['status' => WorkspaceStatus::Orphaned]);
    }

    public function archived(): static
    {
        return $this->state(['status' => WorkspaceStatus::Archived]);
    }

    public function withChildren(int $count): static
    {
        return $this->afterCreating(function (Workspace $workspace) use ($count) {
            Workspace::factory()->count($count)->create([
                'parent_workspace_id' => $workspace->id,
                'owner_user_id'       => $workspace->owner_user_id,
            ]);
        });
    }
}

// database/factories/RoomFactory.php
class RoomFactory extends Factory
{
    public function active(): static    { return $this->state(['status' => RoomStatus::Active]); }
    public function ended(): static     { return $this->state(['status' => RoomStatus::Ended]); }

    public function withParticipants(int $count): static
    {
        return $this->afterCreating(function (Room $room) use ($count) {
            RoomParticipant::factory()->count($count)->create(['room_id' => $room->id]);
        });
    }
}
```

