## Búsqueda global — Meilisearch activa

A partir de esta etapa los assets están siendo indexados. Se activa el input
de búsqueda en `TopBar` que hasta ahora era placeholder.

### `useSearch.js`

```js
// composables/useSearch.js
import { useDebounceFn } from '@vueuse/core'

export function useSearch() {
  const query   = ref('')
  const results = ref([])
  const loading = ref(false)
  const open    = ref(false)

  const doSearch = useDebounceFn(async (q) => {
    if (!q.trim()) { results.value = []; open.value = false; return }
    loading.value = true
    const res     = await api.get('/search', { params: { q } })
    results.value = res.data.data
    open.value    = true
    loading.value = false
  }, 300)

  watch(query, doSearch)

  function navigateTo(result) {
    const path = result.type === 'workspace'
      ? `/app/workspaces/${result.id}`
      : `/app/workspaces/${result.workspace_id}`
    router.push(path)
    open.value  = false
    query.value = ''
  }

  return { query, results, loading, open, navigateTo }
}
```

