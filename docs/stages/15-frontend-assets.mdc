## UI de upload

### Flujo completo

```
1. Usuario hace clic en "Subir archivo" (o drag & drop)
        │
        ▼
2. POST /api/v1/workspaces/{id}/assets/upload-url
   Body: { filename, mime_type, size }
   Response: { asset_id, upload_url, expires_at }
        │
        ▼
3. PUT {upload_url}  ← directo a S3/MinIO, sin pasar por Laravel
   (XMLHttpRequest para poder trackear progreso)
        │
        ▼
4. POST /api/v1/workspaces/{id}/assets/{asset_id}/confirm
        │
        ▼
5. Asset aparece en la lista (actualización local + evento Socket.io)
```

### `useAssetUpload(workspaceId)`

```js
// composables/useAssetUpload.js
export function useAssetUpload(workspaceId) {
  const uploads = ref([])  // [{ file, assetId, progress, status }]

  async function upload(file) {
    const entry = reactive({ file, assetId: null, progress: 0, status: 'pending' })
    uploads.value.push(entry)

    // 1. Obtener URL firmada
    const { data } = await api.post(`/workspaces/${workspaceId}/assets/upload-url`, {
      filename:  file.name,
      mime_type: file.type,
      size:      file.size,
    })
    entry.assetId = data.data.asset_id
    entry.status  = 'uploading'

    // 2. Upload directo a S3 con progreso
    await uploadToS3(data.data.upload_url, file, (pct) => {
      entry.progress = pct
    })

    // 3. Confirmar
    entry.status = 'confirming'
    await api.post(`/workspaces/${workspaceId}/assets/${entry.assetId}/confirm`)
    entry.status = 'done'
  }

  async function uploadToS3(url, file, onProgress) {
    return new Promise((resolve, reject) => {
      const xhr = new XMLHttpRequest()
      xhr.upload.onprogress = (e) => onProgress(Math.round((e.loaded / e.total) * 100))
      xhr.onload  = () => resolve()
      xhr.onerror = () => reject()
      xhr.open('PUT', url)
      xhr.setRequestHeader('Content-Type', file.type)
      xhr.send(file)
    })
  }

  return { uploads, upload }
}
```

