## `lib/api.js` — cliente HTTP

Instancia de Axios configurada con base URL, inyección automática del JWT y del
header `X-Enterprise-ID`, y refresh de token transparente ante 401.

```js
// resources/js/lib/api.js
import axios from 'axios'
import { useSession } from '../composables/core/useSession'
import { useEnterpriseStore } from '../stores/enterpriseStore'

const client = axios.create({
  baseURL: import.meta.env.VITE_API_URL,
  headers: { 'Content-Type': 'application/json' },
})

// ── Request: inyectar Authorization + X-Enterprise-ID ──────────────────────
client.interceptors.request.use((config) => {
  const { accessToken }  = useSession()
  const enterpriseStore  = useEnterpriseStore()

  if (accessToken.value) {
    config.headers['Authorization'] = `Bearer ${accessToken.value}`
  }
  if (enterpriseStore.activeEnterpriseId) {
    config.headers['X-Enterprise-ID'] = enterpriseStore.activeEnterpriseId
  }
  return config
})

// ── Response: refresh automático en 401 ────────────────────────────────────
let isRefreshing  = false
let pendingQueue  = []   // requests en espera del nuevo token

function processQueue(newToken, error = null) {
  pendingQueue.forEach(({ resolve, reject }) =>
    error ? reject(error) : resolve(newToken)
  )
  pendingQueue = []
}

client.interceptors.response.use(
  (response) => response,
  async (error) => {
    const original = error.config

    if (error.response?.status !== 401 || original._retry) {
      return Promise.reject(error)
    }

    const session = useSession()

    if (!session.refreshToken.value) {
      session.clear()
      window.location.href = '/login'
      return Promise.reject(error)
    }

    if (isRefreshing) {
      return new Promise((resolve, reject) => {
        pendingQueue.push({ resolve, reject })
      }).then((token) => {
        original.headers['Authorization'] = `Bearer ${token}`
        return client(original)
      })
    }

    original._retry = true
    isRefreshing    = true

    try {
      const res = await axios.post(
        `${import.meta.env.VITE_API_URL}/auth/refresh`,
        { refresh_token: session.refreshToken.value }
      )
      const { access_token, refresh_token } = res.data.data
      session.setTokens(access_token, refresh_token)
      processQueue(access_token)
      original.headers['Authorization'] = `Bearer ${access_token}`
      return client(original)
    } catch (refreshError) {
      processQueue(null, refreshError)
      session.clear()
      window.location.href = '/login'
      return Promise.reject(refreshError)
    } finally {
      isRefreshing = false
    }
  }
)

export const api = client
```

**Uso en componentes y composables:**
```js
import { api } from '../lib/api'

const res = await api.get('/workspaces')           // GET con token + enterprise
const ws  = await api.post('/workspaces', { name }) // POST
```

Los errores de negocio (4xx) lanzan un axios error con `err.response.data.error.code`.
Los errores de red/5xx también lanzan. Cada vista maneja sus propios errores.

