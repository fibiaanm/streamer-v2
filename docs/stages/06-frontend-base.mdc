## `useSession` — singleton

Los tokens JWT se almacenan en `localStorage` para sobrevivir recarga de página.
En el primer montaje de la app, se leen de `localStorage`; en cada login se actualizan.

```js
// composables/core/useSession.js
import { ref, computed } from 'vue'

const ACCESS_TOKEN_KEY  = 'access_token'
const REFRESH_TOKEN_KEY = 'refresh_token'
const USER_KEY          = 'auth_user'

let _session = null

export function useSession() {
  if (_session) return _session

  const accessToken  = ref(localStorage.getItem(ACCESS_TOKEN_KEY) ?? null)
  const refreshToken = ref(localStorage.getItem(REFRESH_TOKEN_KEY) ?? null)
  const user         = ref(JSON.parse(localStorage.getItem(USER_KEY) ?? 'null'))

  const authenticated = computed(() => !!accessToken.value)

  function setTokens(access, refresh, userData = null) {
    accessToken.value  = access
    refreshToken.value = refresh
    localStorage.setItem(ACCESS_TOKEN_KEY,  access)
    localStorage.setItem(REFRESH_TOKEN_KEY, refresh)
    if (userData) {
      user.value = userData
      localStorage.setItem(USER_KEY, JSON.stringify(userData))
    }
  }

  function clear() {
    accessToken.value  = null
    refreshToken.value = null
    user.value         = null
    localStorage.removeItem(ACCESS_TOKEN_KEY)
    localStorage.removeItem(REFRESH_TOKEN_KEY)
    localStorage.removeItem(USER_KEY)
  }

  _session = { user, accessToken, refreshToken, authenticated, setTokens, clear }
  return _session
}
```

Los tokens se leen de `localStorage` — no se exponen vía Inertia props.
`HandleInertiaRequests` solo comparte datos de usuario (no el token):

```php
// app/Http/Middleware/HandleInertiaRequests.php
public function share(Request $request): array
{
    return [
        // Sin access_token — useSession lo lee de localStorage
        'flash' => fn () => [
            'success' => $request->session()->pull('success'),
            'error'   => $request->session()->pull('error'),
        ],
    ];
}
```

