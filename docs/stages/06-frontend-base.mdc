## `useSocket` — singleton transversal

El socket se instancia una vez al montar `App.vue` y vive durante toda la sesión.
No está ligado a ningún componente específico.

```js
// composables/core/useSocket.js
import { io } from 'socket.io-client'
import { ref } from 'vue'
import { dispatchScopeEffect } from './useScopeEffect'

let _instance = null

export function useSocket() {
  if (_instance) return _instance

  const connected = ref(false)

  function connect(accessToken) {
    if (_instance?.socket) return

    const socket = io(import.meta.env.VITE_SOCKET_URL, {
      auth: { token: `Bearer ${accessToken}` },
      reconnectionAttempts: 5,
    })

    socket.on('connect',    () => { connected.value = true })
    socket.on('disconnect', () => { connected.value = false })

    // Todos los eventos con scope se despachan al registro de effectos
    socket.onAny((event, data) => {
      if (data?.scope) dispatchScopeEffect(data.scope, { event, data })
    })

    function joinScope(scope)  { socket.emit('subscribe',   { scope }) }
    function leaveScope(scope) { socket.emit('unsubscribe', { scope }) }

    _instance = { socket, connected, joinScope, leaveScope }
  }

  return { connect, connected: ref(false), joinScope: () => {}, leaveScope: () => {} }
}
```

