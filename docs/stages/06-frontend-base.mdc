## `useScopeEffect` — socket → composables

Permite que componentes/composables registren handlers para un scope específico.
El socket los invoca cuando llega un evento para ese scope.
Se limpia automáticamente al desmontar el componente.

```js
// composables/core/useScopeEffect.js
import { onUnmounted } from 'vue'

const handlers = new Map() // scope → Set<handler>

export function useScopeEffect(scope, handler) {
  if (!handlers.has(scope)) handlers.set(scope, new Set())
  handlers.get(scope).add(handler)

  onUnmounted(() => {
    handlers.get(scope)?.delete(handler)
    if (handlers.get(scope)?.size === 0) handlers.delete(scope)
  })
}

// Llamado internamente por useSocket
export function dispatchScopeEffect(scope, payload) {
  handlers.get(scope)?.forEach(h => h(payload))
}
```

**Patrón de uso en un componente:**
```js
// WorkspaceView.vue
const ws = useWorkspace(workspaceId)
const { joinScope, leaveScope } = useSocket()

onMounted(() => {
  ws.load()
  joinScope(`workspace:${workspaceId}`)
})

onUnmounted(() => leaveScope(`workspace:${workspaceId}`))

useScopeEffect(`workspace:${workspaceId}`, ({ event, data }) => {
  if (event === 'workspace.asset_created') ws.assets.value.unshift(data)
  if (event === 'workspace.member_added')  useWorkspaceMembers(workspaceId).members.value.push(data)
})
```

