## Socket → workspace via `useScopeEffect`

Al montar `WorkspaceView`, el componente se une al scope de Socket.io y registra
los handlers que el socket puede invocar para actualizar el estado local.

```js
// WorkspaceView.vue
const ws      = useWorkspace(props.id)
const wm      = useWorkspaceMembers(props.id)
const { joinScope, leaveScope } = useSocket()

onMounted(() => {
  ws.load()
  ws.loadChildren()
  ws.loadAssets()
  wm.load()
  joinScope(`workspace:${props.id}`)
})

onUnmounted(() => leaveScope(`workspace:${props.id}`))

useScopeEffect(`workspace:${props.id}`, ({ event, data }) => {
  switch (event) {
    case 'workspace.asset_created':
      ws.assets.value.unshift(data)
      break
    case 'workspace.asset_deleted':
      ws.assets.value = ws.assets.value.filter(a => a.id !== data.id)
      break
    case 'workspace.member_added':
      wm.members.value.push(data)
      break
    case 'workspace.member_removed':
      wm.members.value = wm.members.value.filter(m => m.user_id !== data.user_id)
      break
  }
})
```

