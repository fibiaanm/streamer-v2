# Etapa 13 — Frontend Workspaces

## Objetivo
Vista de explorador de archivos con los workspaces raíz como punto de entrada,
composables por workspace compartidos por ID (registro reactivo singleton),
sistema de capabilities por workspace, y configuración de roles/permisos/miembros.

---

## `useWorkspace(id)` — shared by ID

Retorna siempre la misma instancia reactiva para el mismo `workspaceId`.
Carga sus datos una sola vez. Múltiples componentes comparten el mismo estado sin duplicar fetches.

```js
// composables/useWorkspace.js
import { ref, computed } from 'vue'
import { api } from '../lib/api'

const registry = new Map()

export function useWorkspace(workspaceId) {
  if (!registry.has(workspaceId)) {
    registry.set(workspaceId, createWorkspaceState(workspaceId))
  }
  return registry.get(workspaceId)
}

function createWorkspaceState(id) {
  const status       = ref('idle')    // 'idle' | 'loading' | 'ready' | 'error'
  const workspace    = ref(null)
  const children     = ref([])        // sub-workspaces
  const assets       = ref([])
  const capabilities = ref([])        // lista de permission strings del usuario en este workspace

  const can = (permission) => capabilities.value.includes(permission)

  const isLoading = computed(() => status.value === 'loading')
  const isReady   = computed(() => status.value === 'ready')

  async function load() {
    if (status.value === 'ready' || status.value === 'loading') return
    status.value = 'loading'
    try {
      const [wsRes, capRes] = await Promise.all([
        api.get(`/workspaces/${id}`),
        api.get(`/workspaces/${id}/capabilities`),
      ])
      workspace.value    = wsRes.data.data
      capabilities.value = capRes.data.data
      status.value       = 'ready'
    } catch {
      status.value = 'error'
    }
  }

  async function loadChildren() {
    const res   = await api.get(`/workspaces/${id}/children`)
    children.value = res.data.data
  }

  async function loadAssets() {
    const res  = await api.get(`/workspaces/${id}/assets`)
    assets.value = res.data.data
  }

  return { status, workspace, children, assets, capabilities, can, isLoading, isReady, load, loadChildren, loadAssets }
}
```

**Uso con guard de status:**
```vue
<template>
  <div v-if="ws.isLoading.value">Cargando...</div>
  <div v-else-if="ws.isReady.value">
    <h1>{{ ws.workspace.value.name }}</h1>
    <button v-if="ws.can('workspace.invite')">Invitar miembro</button>
  </div>
</template>

<script setup>
const ws = useWorkspace(props.id)
onMounted(() => ws.load())
</script>
```

