## `useWorkspaceMembers(workspaceId)` y `useTeamMembers(enterpriseId)`

Mismo patrón registry shared-by-ID:

```js
// composables/useWorkspaceMembers.js
const membersRegistry = new Map()

export function useWorkspaceMembers(workspaceId) {
  if (!membersRegistry.has(workspaceId)) {
    membersRegistry.set(workspaceId, createMembersState('workspace', workspaceId))
  }
  return membersRegistry.get(workspaceId)
}

// composables/useTeamMembers.js
const teamRegistry = new Map()

export function useTeamMembers(enterpriseId) {
  if (!teamRegistry.has(enterpriseId)) {
    teamRegistry.set(enterpriseId, createMembersState('enterprise', enterpriseId))
  }
  return teamRegistry.get(enterpriseId)
}

function createMembersState(type, id) {
  const status  = ref('idle')
  const members = ref([])

  async function load() {
    if (status.value !== 'idle') return
    status.value = 'loading'
    const endpoint = type === 'workspace'
      ? `/workspaces/${id}/members`
      : `/enterprises/current/members`
    const res     = await api.get(endpoint)
    members.value = res.data.data
    status.value  = 'ready'
  }

  return { status, members, load }
}
```

