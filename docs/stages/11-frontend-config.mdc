## `useCapabilities` — permisos enterprise del usuario

Singleton. Carga los permisos del usuario en la empresa activa una sola vez.

```js
// composables/useCapabilities.js
let _instance = null

export function useCapabilities() {
  if (_instance) return _instance

  const permissions = ref([])
  const status      = ref('idle')
  const can         = (p) => permissions.value.includes(p)

  async function load() {
    if (status.value !== 'idle') return
    status.value      = 'loading'
    const res         = await api.get('/enterprises/current/capabilities')
    permissions.value = res.data.data
    status.value      = 'ready'
  }

  _instance = { permissions, status, can, load }
  return _instance
}
```

Endpoint backend:
```
GET /api/v1/enterprises/current/capabilities
→ { "data": ["enterprise.admin", "enterprise.invite_member", "enterprise.manage_roles", "enterprise.billing", "enterprise.create_workspace"] }
```

