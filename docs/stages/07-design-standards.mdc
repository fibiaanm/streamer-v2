## Tokens Tailwind

```js
// tailwind.config.js
module.exports = {
  theme: {
    extend: {
      colors: {
        glass: {
          DEFAULT: 'rgba(255, 255, 255, 0.06)',
          hover:   'rgba(255, 255, 255, 0.10)',
          active:  'rgba(255, 255, 255, 0.15)',
          border:  'rgba(255, 255, 255, 0.12)',
        },
        brand: {
          DEFAULT: '#7c3aed',   // violet-600
          light:   '#a78bfa',
          dark:    '#5b21b6',
        },
        surface: {
          base:   'rgba(255, 255, 255, 0.04)',
          raised: 'rgba(255, 255, 255, 0.08)',
          modal:  'rgba(10, 10, 20, 0.85)',
        },
      },
      backdropBlur: {
        glass: '16px',
        modal: '24px',
        bar:   '20px',
      },
    },
  },
}
```

