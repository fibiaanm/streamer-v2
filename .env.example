# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=streamer-v2
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── Base de datos ────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=streamer
DB_USERNAME=streamer
DB_PASSWORD=secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Session, caché y colas (redis obligatorio) ───────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_TTL=15        # minutos
JWT_REFRESH_TTL=43200    # minutos (30 días)

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=streamer
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001    # cambiar si el puerto está ocupado por otro proyecto

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@streamer.local
MAIL_FROM_NAME="${APP_NAME}"

# ─── Socket.io ────────────────────────────────────────────────────────────────
SOCKETIO_URL=http://socketio:3000
SOCKETIO_SECRET=          # shared secret para comunicación interna app → socketio

# ─── Empresa (header HTTP) ────────────────────────────────────────────────────
ENTERPRISE_HEADER=X-Enterprise-ID

# ─── Meilisearch ──────────────────────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=localdevkey1234567890    # mínimo 16 chars; cambiar en producción

# ─── Laravel Scout ────────────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch

# ─── pgAdmin (solo desarrollo) ────────────────────────────────────────────────
PGADMIN_EMAIL=admin@streamer.dev
PGADMIN_PASSWORD=admin

# ─── Puertos expuestos (cambiar si hay conflictos con otros proyectos) ─────────
APP_PORT=8000
SOCKETIO_PORT=3000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
PGADMIN_PORT=5050
REDIS_INSIGHT_PORT=5540
MEILISEARCH_PORT=7700
