# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=streamer-v2
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://tudominio.com
APP_FRONTEND_URL=https://tudominio.com

# ─── Base de datos — DO Managed Postgres ──────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=                          # host del cluster managed (DO te lo da)
DB_PORT=25060                     # puerto por defecto de DO Managed Postgres
DB_DATABASE=streamer
DB_USERNAME=streamer
DB_PASSWORD=                      # contraseña del usuario managed
DB_SSLMODE=require

# ─── Redis — DO Managed Redis ─────────────────────────────────────────────────
REDIS_HOST=                       # host del cluster managed (DO te lo da)
REDIS_PORT=25061                  # puerto por defecto de DO Managed Redis
REDIS_PASSWORD=                   # contraseña del cluster managed
REDIS_SCHEME=tls

# ─── Session, caché y colas ───────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                       # mínimo 32 chars, aleatorio
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=43200

# ─── S3 — DO Spaces ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=                # Spaces access key (DO → API → Spaces Keys)
AWS_SECRET_ACCESS_KEY=            # Spaces secret key
AWS_DEFAULT_REGION=               # ej. nyc3, ams3, sfo3
AWS_BUCKET=                       # nombre del bucket en Spaces
AWS_ENDPOINT=https://${AWS_DEFAULT_REGION}.digitaloceanspaces.com
AWS_URL=https://${AWS_BUCKET}.${AWS_DEFAULT_REGION}.cdn.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false
MEDIA_DISK=s3

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=                      # TBD: resend | mailgun | postmark | ses
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tudominio.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Socket.io ────────────────────────────────────────────────────────────────
SOCKETIO_URL=http://socketio:3000
SOCKETIO_SECRET=                  # shared secret, mínimo 32 chars

# ─── Empresa (header HTTP) ────────────────────────────────────────────────────
ENTERPRISE_HEADER=X-Enterprise-ID

# ─── Búsqueda ─────────────────────────────────────────────────────────────────
SCOUT_DRIVER=                     # TBD: null (desactivado) | meilisearch (Meilisearch Cloud)
MEILISEARCH_HOST=
MEILISEARCH_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ─── Grafana Cloud (Fluent Bit lee estas vars desde el entorno del pod) ────────
GRAFANA_USER_ID=
GRAFANA_API_KEY=
